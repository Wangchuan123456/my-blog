---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
const sortedPosts = blogPosts.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

// 提取所有标签
const allTags = [...new Set(sortedPosts.flatMap(p => p.data.tags))].sort();
---

<Layout title="文章 · 前端日志">
  <div class="container-wide page-header">
    <h1>📚 全部文章</h1>
    <p class="page-desc">共 {sortedPosts.length} 篇文章 · 持续更新中</p>

    {allTags.length > 0 && (
      <div class="filter-tags">
        <button class="filter-tag active" data-filter="all">全部</button>
        {allTags.map(tag => (
          <button class="filter-tag" data-filter={tag}>{tag}</button>
        ))}
      </div>
    )}
  </div>

  <div class="container-wide">
    {sortedPosts.length === 0 ? (
      <div class="empty-state">
        <p>还没有文章，马上就来 🚀</p>
      </div>
    ) : (
      <div class="blog-grid" id="blog-grid">
        {sortedPosts.map(post => (
          <a href={`/blog/${post.id}`} class="blog-card" data-tags={post.data.tags.join(',')}>
            <div class="blog-card-meta">
              <time>{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
              <span class="blog-card-category">{post.data.category}</span>
            </div>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-desc">{post.data.description}</p>
            <div class="blog-card-tags">
              {post.data.tags.map(tag => <span class="mini-tag">{tag}</span>)}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>

  <!-- 标签筛选 JS -->
  <script>
    const buttons = document.querySelectorAll('.filter-tag');
    const cards = document.querySelectorAll('.blog-card');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.getAttribute('data-filter') || '';
        cards.forEach(card => {
          if (!(card instanceof HTMLElement)) return;
          if (filter === 'all') {
            card.style.display = '';
          } else {
            const tags = (card.getAttribute('data-tags') || '').split(',');
            card.style.display = tags.includes(filter) ? '' : 'none';
          }
        });
      });
    });
  </script>
</Layout>

<style>
  .page-header {
    padding: 2.5rem 1.5rem 0;
  }
  .page-header h1 {
    font-size: 1.8rem;
    font-weight: 700;
  }
  .page-desc {
    color: var(--text-secondary);
    margin-top: 0.3rem;
  }

  .filter-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.5rem 0;
  }
  .filter-tag {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 0.35rem 1rem;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--text-secondary);
    transition: all 0.15s;
    font-family: inherit;
  }
  .filter-tag:hover { border-color: var(--accent); color: var(--accent); }
  .filter-tag.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .blog-grid {
    display: grid;
    gap: 1rem;
    padding: 0 1.5rem 3rem;
  }

  .blog-card {
    display: block;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: box-shadow 0.2s, transform 0.2s;
    color: var(--text);
  }
  .blog-card:hover {
    box-shadow: var(--card-shadow);
    transform: translateY(-3px);
    opacity: 1;
  }
  .blog-card-meta {
    display: flex;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }
  .blog-card-category {
    background: var(--accent-light);
    color: var(--accent);
    padding: 0.05rem 0.5rem;
    border-radius: 10px;
    font-weight: 500;
  }
  .blog-card-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .blog-card-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.7rem;
  }
  .empty-state {
    text-align: center;
    padding: 4rem 1.5rem;
    color: var(--text-secondary);
  }
</style>

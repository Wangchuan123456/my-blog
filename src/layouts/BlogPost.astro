---
import { type CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';

export interface Props {
  entry: CollectionEntry<'blog'>;
  prev?: CollectionEntry<'blog'>;
  next?: CollectionEntry<'blog'>;
}

const { entry, prev, next } = Astro.props;
const { Content } = await entry.render();
const { title, description, pubDate, updatedDate, tags, heroImage, demo } = entry.data;

// 标签分类映射
const tagCategories = {
  html: { label: 'HTML', colors: ['#d97706', '#fef3c7'] },
  css:  { label: 'CSS',  colors: ['#2563eb', '#dbeafe'] },
  js:   { label: 'JS',   colors: ['#ca8a04', '#fef9c3'] },
  basics: { label: '基础', colors: ['#0d9488', '#ccfbf1'] },
  other:  { label: '其他', colors: ['#6b7280', '#f3f4f6'] },
};

function getTagCategory(tag: string) {
  const t = tag.toLowerCase();
  // HTML 相关
  const htmlKeys = ['html', 'header', 'nav', 'main', 'div', 'span', 'img', 'a标签', 'form', 'table', 'ul', 'ol', 'li', 'dl', 'dt', 'dd', 'input', 'select', 'textarea', 'button', 'audio', 'video', 'iframe', '语义化', '网页结构', '块级元素', '行内元素', '嵌套规则', '图片标签', '图片格式', '路径', '相对路径', '绝对路径', '超链接', '锚点链接', '字符实体', '转义', '特殊符号', '列表', '合并单元格', 'colspan', 'rowspan', '多媒体', '入门'];
  if (htmlKeys.some(k => t.includes(k))) return 'html';
  // CSS 相关
  const cssKeys = ['css', '样式表', '选择器', '布局', '字体', '文本', '背景', '浮动', 'flex', '弹性盒', '盒子模型', '边框', '关系选择器', '后代选择器', '子代选择器', '兄弟选择器', '组合选择器', '权重', '优先级', '伪类', '伪元素', '分组选择器', '结构性', '结构伪类', '表单伪类', '属性选择器', '精灵图', '字体图标', 'iconfont', '过渡', '盒子阴影', 'display', 'float', 'clearfix', '渐变', '行内样式', '内部样式', '外部样式', 'link', 'margin', 'padding', 'border-radius', 'box-sizing', 'color', 'font-size', 'text-align', 'line-height', 'specificity', '背景图', 'hover', 'focus', '链接', 'first-child', 'last-child', 'nth-child', '隔行变色', 'before', 'after', 'disabled', 'checked', 'placeholder', 'background', 'linear-gradient', 'box-shadow', 'transition', 'css初始化', 'css sprites', 'background-position', '性能优化', 'flexbox'];
  if (cssKeys.some(k => t.includes(k))) return 'css';
  // JS 相关（预留）
  const jsKeys = ['js', 'javascript', 'es', 'react', 'vue', 'angular', 'node'];
  if (jsKeys.some(k => t.includes(k))) return 'js';
  // 基础概念
  const basicsKeys = ['入门', '基础', '教程', '初学'];
  if (basicsKeys.some(k => t.includes(k))) return 'basics';
  return 'other';
}

const MAX_VISIBLE_TAGS = 5;
const hasHiddenTags = tags.length > MAX_VISIBLE_TAGS;
---

<Layout title={title} description={description}>
  <article class="post">
    <!-- 标题区 -->
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {updatedDate && (
          <>
            <span class="meta-sep">·</span>
            <span class="updated">更新于 {updatedDate.toLocaleDateString('zh-CN')}</span>
          </>
        )}
        <span class="meta-sep">·</span>
        <span class="reading-time">约 {Math.ceil(entry.body.length / 500)} 分钟阅读</span>
      </div>
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-desc">{description}</p>}
      {tags.length > 0 && (
        <div class="tags" id="post-tags">
          {tags.slice(0, MAX_VISIBLE_TAGS).map(tag => {
            const cat = getTagCategory(tag);
            const [color, bg] = tagCategories[cat].colors;
            return <span class="tag" style={{ '--tag-color': color, '--tag-bg': bg }}>{tag}</span>;
          })}
          {hasHiddenTags && (
            <>
              {tags.slice(MAX_VISIBLE_TAGS).map(tag => {
                const cat = getTagCategory(tag);
                const [color, bg] = tagCategories[cat].colors;
                return <span class="tag tag-hidden" style={{ '--tag-color': color, '--tag-bg': bg }}>{tag}</span>;
              })}
              <button class="tag-toggle" id="tag-toggle-btn">+{tags.length - MAX_VISIBLE_TAGS}</button>
            </>
          )}
        </div>
      )}
      {demo && (
        <a href={demo} target="_blank" class="demo-btn">🌐 在线演示</a>
      )}
    </header>

    <!-- 封面图 -->
    {heroImage && <img src={heroImage} alt={title} class="hero" />}

    <!-- 正文 -->
    <div class="post-content">
      <Content />
    </div>

    <!-- 文章底部导航 -->
    <nav class="post-footer">
      <div class="post-nav-inner">
        {prev && (
          <a href={`/blog/${prev.id}`} class="post-nav-link prev">
            <span class="post-nav-label">← 上一篇</span>
            <span class="post-nav-title">{prev.data.title}</span>
          </a>
        )}
        {next && (
          <a href={`/blog/${next.id}`} class="post-nav-link next">
            <span class="post-nav-label">下一篇 →</span>
            <span class="post-nav-title">{next.data.title}</span>
          </a>
        )}
      </div>
    </nav>
  </article>

  <script>
    const tagsEl = document.getElementById('post-tags');
    const toggleBtn = document.getElementById('tag-toggle-btn');
    if (tagsEl && toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        tagsEl.classList.toggle('expanded');
      });
    }
  </script>
</Layout>

<style>
  .post {
    max-width: 680px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }
  .post-header {
    margin-bottom: 2.5rem;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 0.8rem;
  }
  .meta-sep { color: var(--border); }
  .updated { font-style: italic; }
  .post-title {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.8rem;
  }
  .post-desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
    align-items: center;
  }
  .tag {
    padding: 0.2rem 0.65rem;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--tag-color);
    background: var(--tag-bg);
    transition: opacity 0.2s;
  }
  .tag:hover {
    opacity: 0.8;
  }
  .tag-hidden {
    display: none;
  }
  .tags.expanded .tag-hidden {
    display: inline-flex;
  }
  .tags.expanded .tag-toggle {
    display: none;
  }
  .tag-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    background: var(--bg-secondary);
    color: var(--text-secondary);
    border: 1px dashed var(--border);
    font-family: inherit;
    transition: all 0.15s;
  }
  .tag-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-light);
  }
  .hero {
    width: 100%;
    border-radius: var(--radius);
    margin-bottom: 2.5rem;
  }
  .demo-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    padding: 0.5rem 1.2rem;
    background: var(--accent);
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
  }

  /* 文章正文排版 */
  .post-content h2 { font-family: var(--font-serif); font-size: 1.5rem; margin: 2.5rem 0 0.8rem; }
  .post-content h3 { font-family: var(--font-serif); font-size: 1.25rem; margin: 2rem 0 0.6rem; }
  .post-content p { margin-bottom: 1.5rem; }
  .post-content ul, .post-content ol { margin: 0.5rem 0 1.2rem 1.5rem; }
  .post-content li { margin-bottom: 0.3rem; }
  .post-content blockquote {
    border-left: 4px solid var(--accent);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: var(--bg-secondary);
    border-radius: 0 var(--radius) var(--radius) 0;
    color: var(--text-secondary);
    font-style: italic;
    font-size: 1.05rem;
  }
  .post-content a { text-decoration: underline; }
  .post-content img { margin: 1.5rem 0; }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .post-nav-inner {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .post-nav-link {
    flex: 1;
    display: block;
    padding: 0.8rem 1rem;
    border-radius: 8px;
    transition: background 0.2s;
  }
  .post-nav-link.next {
    text-align: right;
  }
  .post-nav-link:hover {
    background: var(--bg-secondary);
  }
  .post-nav-label {
    display: block;
    font-size: 0.82rem;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    margin-bottom: 0.2rem;
  }
  .post-nav-title {
    display: block;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    font-family: var(--font-serif);
    line-height: 1.4;
  }
  .post-nav-link:only-child.next {
    margin-left: auto;
  }
</style>
